# Code-Fundi MCP Server Configuration
#
# API key for authenticating with the Code-Fundi API.
# Optional if you plan to use the code-fundi-auth-* tools to sign in dynamically.
CODEFUNDI_API_KEY=your_api_key_here

# Base URL for the Code-Fundi API (optional, defaults to https://api.codefundi.app)
CODEFUNDI_BASE_URL=https://api.codefundi.app
