{
  "name": "code-fundi-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Code-Fundi API — search, research, index, and manage code repositories via any MCP-compatible AI assistant.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "code-fundi-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "inspect": "npx fastmcp inspect src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "keywords": [
    "mcp",
    "code-fundi",
    "codefundi",
    "ai",
    "code-search",
    "fastmcp"
  ],
  "license": "MIT",
  "dependencies": {
    "fastmcp": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
